# Turso (hosted SQLite)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Resend (뉴스레터, Phase 4)
RESEND_API_KEY=re_...

# Site URL (뉴스레터 링크용)
SITE_URL=https://your-site.vercel.app

# Cron Secret (API 보호용)
CRON_SECRET=your-random-secret
